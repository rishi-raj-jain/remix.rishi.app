{
  "name": "remix.rishi.app",
  "dependencies": {
    "@remix-run/express": "^1.2.1",
    "@remix-run/react": "^1.2.1",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "npm-run-all": "^4.1.5",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "remix": "^1.2.1",
    "rewire": "^6.0.0",
    "storyblok-js-client": "^4.2.1"
  },
  "devDependencies": {
    "@layer0/cli": "^4.10.2",
    "@layer0/core": "^4.10.2",
    "@layer0/devtools": "^4.10.2",
    "@layer0/express": "^4.10.2",
    "@layer0/prefetch": "^4.10.2",
    "@layer0/react": "^4.10.2",
    "@remix-run/dev": "^1.2.1",
    "@vercel/nft": "^0.17.5",
    "autoprefixer": "^10.4.2",
    "concurrently": "^7.0.0",
    "nodemon": "^2.0.15",
    "postcss": "^8.4.6",
    "prettier": "^2.5.1",
    "prop-types": "^15.8.1",
    "tailwindcss": "^3.0.23",
    "remark": "^12.0.1",
    "remark-html": "^13.0.1",
    "remark-prism": "^1.1.14",
    "@tailwindcss/line-clamp": "^0.2.1",
    "@tailwindcss/typography": "^0.5.2"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run generate:css -- --minify",
    "build:remix": "cross-env NODE_ENV=production remix build",
    "dev": "run-p dev:*",
    "dev:css": "npm run generate:css -- --watch",
    "dev:remix": "cross-env NODE_ENV=development remix watch",
    "generate:css": "npx tailwindcss -i ./styles/tailwind.css -o ./app/tailwind.css",
    "postinstall": "remix setup node",
    "dev:node": "cross-env NODE_ENV=development nodemon ./build/index.js",
    "start": "cross-env NODE_ENV=production node ./build/index.js",
    "format": "prettier --write '**/*' --ignore-unknown",
    "start:dev": "cross-env NODE_ENV=development node server/index.js",
    "layer0:build": "layer0 build",
    "layer0:run": "layer0 run -p",
    "layer0:deploy": "layer0 deploy -e=remix"
  }
}
